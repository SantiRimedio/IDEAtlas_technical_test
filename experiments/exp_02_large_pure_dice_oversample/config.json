{
  "name": "large_pure_dice_oversample",
  "use_dice": true,
  "use_focal": false,
  "focal_alpha": 0.85,
  "focal_gamma": 2.5,
  "dice_focal_ratio": 3.0,
  "class2_weight_multiplier": 1.0,
  "normalize_class_weights": true,
  "epochs": 40,
  "lr": 0.0001,
  "dropout_rate": 0.3,
  "batch_size": 8,
  "early_stopping_patience": 12,
  "reduce_lr_patience": 6,
  "monitor": "val_class2_recall",
  "monitor_mode": "max",
  "den_prefix": "DEN",
  "den_bands": 1,
  "use_large_grid": true,
  "class2_oversample_factor": 5,
  "block": "d",
  "notes": "Pure dice + 5\u00d7 class-2 oversampling on large grid"
}